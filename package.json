{
  "name": "brainrot-lang",
  "displayName": "BrainRot Lang",
  "description": "Syntax highlighting, icons and hover docs for BrainRot Lang (.brt)",
  "version": "1.0.0",
  "publisher": "TanveerRajpurohit",
  "engines": { "vscode": "^1.74.0" },
  "categories": ["Programming Languages"],
  "icon": "icons/brainrot-icon.png",
  "main": "./extension.js",
  "activationEvents": ["onLanguage:brainrot"],
  "repository": {
    "type": "git",
    "url": "https://github.com/Tanveer-rajpurohit/brainrot-lang"
  },
  "contributes": {
    "languages": [{
      "id": "brainrot",
      "aliases": ["BrainRot", "brainrot"],
      "extensions": [".brt"],
      "configuration": "./language-configuration.json",
      "icon": {
        "light": "./icons/brainrot-icon.png",
        "dark":  "./icons/brainrot-icon.png"
      }
    }],
    "grammars": [{
      "language": "brainrot",
      "scopeName": "source.brainrot",
      "path": "./syntaxes/brainrot.tmLanguage.json"
    }],
    "snippets": [{
      "language": "brainrot",
      "path": "./snippets/brainrot.json"
    }]
  }
}
