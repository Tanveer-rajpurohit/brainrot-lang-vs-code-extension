{
  "name": "BrainRot",
  "scopeName": "source.brainrot",
  "fileTypes": ["brt"],
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#booleans" },
    { "include": "#builtins" },
    { "include": "#control-keywords" },
    { "include": "#declaration-keywords" },
    { "include": "#function-calls" },
    { "include": "#operators" },
    { "include": "#punctuation" },
    { "include": "#identifiers" }
  ],
  "repository": {
    "comments": {
      "name": "comment.line.number-sign.brainrot",
      "match": "#.*$"
    },
    "strings": {
      "name": "string.quoted.double.brainrot",
      "begin": "\"",
      "end": "\"",
      "patterns": [{
        "name": "constant.character.escape.brainrot",
        "match": "\\\\."
      }]
    },
    "numbers": {
      "name": "constant.numeric.brainrot",
      "match": "\\b[0-9]+(\\.[0-9]+)?\\b"
    },
    "booleans": {
      "name": "constant.language.brainrot",
      "match": "\\b(fr_fr|cap|ghosted)\\b"
    },
    "builtins": {
      "name": "support.function.brainrot",
      "match": "\\b(say_my_name)\\b"
    },
    "control-keywords": {
      "name": "keyword.control.brainrot",
      "match": "\\b(chat_is_this_real|wait_hold_up|nah_bro|on_repeat|run_it_back|mission_abort|skip_this_one)\\b"
    },
    "declaration-keywords": {
      "name": "keyword.other.brainrot",
      "match": "\\b(trust_me_bro|let_him_cook|take_this)\\b"
    },
    "function-calls": {
      "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*(\\()",
      "captures": {
        "1": { "name": "entity.name.function.brainrot" },
        "2": { "name": "punctuation.paren.open.brainrot" }
      }
    },
    "operators": {
      "name": "keyword.operator.brainrot",
      "match": "(\\*\\*|\\+\\+|--|==|!=|<=|>=|&&|\\|\\||[+\\-*/%=!<>]|\\+=|-=|\\*=|/=)"
    },
    "punctuation": {
      "patterns": [
        {
          "name": "punctuation.paren.open.brainrot",
          "match": "\\("
        },
        {
          "name": "punctuation.paren.close.brainrot",
          "match": "\\)"
        },
        {
          "name": "punctuation.brace.open.brainrot",
          "match": "\\{"
        },
        {
          "name": "punctuation.brace.close.brainrot",
          "match": "\\}"
        },
        {
          "name": "punctuation.bracket.open.brainrot",
          "match": "\\["
        },
        {
          "name": "punctuation.bracket.close.brainrot",
          "match": "\\]"
        },
        {
          "name": "punctuation.separator.brainrot",
          "match": "[,;]"
        }
      ]
    },
    "identifiers": {
      "name": "variable.other.brainrot",
      "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b"
    }
  }
}
